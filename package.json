{
  "name": "hinana-video-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Hinana desktop video editor prototype",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "studio.hinana.HinanaStudio",
    "productName": "HINANA STUDIO",
    "icon": "HinanaStudioIcon.png",
    "extraResources": [
      {
        "from": "HinanaStudioIcon.png",
        "to": "HinanaStudioIcon.png"
      }
    ]
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && node scripts/launch-electron.cjs\"",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "start": "node scripts/launch-electron.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "wait-on": "latest"
  }
}
