{
  "name": "hinana-video-editor",
  "version": "1.0.0-beta.1",
  "private": true,
  "license": "UNLICENSED",
  "author": "비나래",
  "description": "Hinana desktop video editor beta",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "studio.hinana.HinanaStudio",
    "productName": "HINANA STUDIO",
    "directories": { "output": "release" },
    "icon": "HinanaStudioIcon.png",
    "extraResources": [
      { "from": "HinanaStudioIcon.png", "to": "HinanaStudioIcon.png" }
    ],
    "asar": true,
    "asarUnpack": ["node_modules/ffmpeg-static/**"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "HinanaStudioIcon.png",
      "artifactName": "HINANA-STUDIO-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "HinanaStudioIcon.png",
      "category": "public.app-category.video",
      "artifactName": "HINANA-STUDIO-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "HINANA STUDIO ${version}",
      "writeUpdateInfo": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HINANA STUDIO"
    }
  },
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://localhost:5173 && node scripts/launch-electron.cjs\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "start": "node scripts/launch-electron.cjs",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --arm64"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "wait-on": "latest"
  }
}
